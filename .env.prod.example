# ── Environnement production Docker ─────────────────────────────
ENV=production
GIN_MODE=release
LOG_LEVEL=info
POSTGRES_SSLMODE=prefer
POSTGRES_PORT_BIND=127.0.0.1:5432
REDIS_PORT_BIND=127.0.0.1:6379
BACKEND_PORT_BIND=127.0.0.1:8080
FRONTEND_PORT_BIND=127.0.0.1:3000
NEXT_PUBLIC_API_URL=/api/v1
LETSENCRYPT_DIR=/opt/mynapay/letsencrypt
CERTBOT_WWW_DIR=/opt/mynapay/certbot-www

# ── Secrets obligatoires ────────────────────────────────────────
# A renseigner avant le deploiement. Ne jamais commiter .env.prod.
DB_PASSWORD=
REDIS_PASSWORD=
JWT_SECRET=
JWT_SECRET_PREVIOUS=
FIELD_ENCRYPTION_KEY=

# ── Sessions et securite ────────────────────────────────────────
JWT_EXPIRY_HOURS=2
REFRESH_EXPIRY_DAYS=7
SEED_SUPER_ADMIN=false
TOTP_REQUIRED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_FINANCIAL_PER_MIN=5

# ── Super admin initial, seulement si SEED_SUPER_ADMIN=true ─────
SUPER_ADMIN_EMAIL=admin@mynapay.bf
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# ── Orange Money BF — Online Payment API XML-RPC ────────────────
ORANGE_MONEY_ENV=production
ORANGE_MONEY_TEST_URL=https://testom.orange.bf/
ORANGE_MONEY_PROD_URL=https://apiom.orange.bf/
ORANGE_MONEY_MERCHANT_MSISDN=
ORANGE_MONEY_BENEFICIARY_MSISDN=
ORANGE_MONEY_USSD_MSISDN=
ORANGE_MONEY_API_USERNAME=
ORANGE_MONEY_API_PASSWORD=
ORANGE_MONEY_PROVIDER=101
ORANGE_MONEY_PAYID=12
ORANGE_MONEY_CASHIN_TOKEN_URL=
ORANGE_MONEY_CASHIN_URL=
ORANGE_MONEY_CASHIN_API_KEY=
ORANGE_MONEY_CASHIN_USERNAME=
ORANGE_MONEY_CASHIN_PASSWORD=
ORANGE_MONEY_AGENT_ALIAS=
ORANGE_MONEY_AGENT_PIN=
ORANGE_MONEY_PIN_PUBLIC_KEY=./certs/orange/pin_public_key.pem
ORANGE_MONEY_CERTS_DIR=/opt/mynapay/secrets/orange
ORANGE_MONEY_CERT_PUBLIC_CONTAINER=/run/secrets/orange/star_orange_bf.pem
ORANGE_MONEY_CERT_PRIVATE_CONTAINER=/run/secrets/orange/OrangeBFV22026.key
ORANGE_MONEY_PIN_PUBLIC_KEY_CONTAINER=/run/secrets/orange/pin_public_key.pem

# ── Moov Money BF ───────────────────────────────────────────────
MOOV_ENV=test
MOOV_TEST_URL=https://uat.moov-money.bf:38443
MOOV_PROD_URL=
MOOV_USERNAME=
MOOV_PASSWORD=

# ── Email transactionnel ────────────────────────────────────────
MAIL_PROVIDER=smtp
MAIL_FROM_EMAIL=no_reply@myna-etoile.com
MAIL_FROM_NAME=MynaPay
MAIL_API_URL=
MAIL_API_KEY=
MAIL_TIMEOUT_SECONDS=10
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=no_reply@myna-etoile.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993

# ── Workers ─────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
MAX_RETRIES=3
RETRY_DELAY_SECONDS=30

# ── Plateforme ─────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=0.015
VALIDATION_THRESHOLD=500000

# ── Backup PostgreSQL ───────────────────────────────────────────
BACKUP_PG_DATABASE=masspay_bf
BACKUP_PG_USER=masspay
BACKUP_PG_PASSWORD=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-west-3
