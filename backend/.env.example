# ── Server ─────────────────────────────────────────────────────
ENV=dev
PORT=8080
GIN_MODE=debug   # release en prod
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────
# sslmode=require en production, prefer en staging, disable uniquement en dev local
DATABASE_URL=postgres://masspay:secret@localhost:5432/masspay_bf?sslmode=disable

# ── Redis ──────────────────────────────────────────────────────
# REDIS_PASSWORD obligatoire — generer avec : openssl rand -hex 24
REDIS_PASSWORD=changeme_redis_strong_password
REDIS_URL=redis://:changeme_redis_strong_password@localhost:6379

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=changeme_min_32_chars_in_production
JWT_EXPIRY_HOURS=24
REFRESH_EXPIRY_DAYS=30

# ── Securite champs sensibles (AES-256-GCM) ────────────────────
# Obligatoire en staging et production
# Generer avec : openssl rand -hex 32
FIELD_ENCRYPTION_KEY=

# ── 2FA TOTP ───────────────────────────────────────────────────
# Si true, les actions financieres (execute batch, recharge) exigent un code TOTP actif
TOTP_REQUIRED=false

# ── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_FINANCIAL_PER_MIN=5

# ── Seed super admin (dev) ─────────────────────────────────────
SEED_SUPER_ADMIN=true
SUPER_ADMIN_EMAIL=admin@mynapay.bf
SUPER_ADMIN_PASSWORD=MynaPay@2026!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# ── Orange Money BF — Online Payment API (XML-RPC) ─────────────
# IMPORTANT : les certificats ne doivent jamais etre commites dans git
# Placer les fichiers dans ./certs/orange/ (dossier dans .gitignore)
ORANGE_MONEY_ENV=test
ORANGE_MONEY_TEST_URL=https://testom.orange.bf/
ORANGE_MONEY_PROD_URL=https://apiom.orange.bf/
ORANGE_MONEY_MERCHANT_MSISDN=
ORANGE_MONEY_BENEFICIARY_MSISDN=
ORANGE_MONEY_USSD_MSISDN=
ORANGE_MONEY_API_USERNAME=
ORANGE_MONEY_API_PASSWORD=
ORANGE_MONEY_PROVIDER=101
ORANGE_MONEY_PAYID=12
ORANGE_MONEY_CASHIN_TOKEN_URL=
ORANGE_MONEY_CASHIN_URL=
ORANGE_MONEY_CASHIN_API_KEY=
ORANGE_MONEY_CASHIN_USERNAME=
ORANGE_MONEY_CASHIN_PASSWORD=
ORANGE_MONEY_AGENT_ALIAS=
ORANGE_MONEY_AGENT_PIN=
ORANGE_MONEY_PIN_PUBLIC_KEY=./certs/orange/pin_public_key.pem
ORANGE_MONEY_CERT_PUBLIC=./certs/orange/star_orange_bf.pem
ORANGE_MONEY_CERT_PRIVATE=./certs/orange/OrangeBFV22026.key

# ── Moov Money BF — Online Merchant USSD Push (Huawei) ─────────
MOOV_ENV=test
MOOV_TEST_URL=https://uat.moov-money.bf:38443
MOOV_PROD_URL=
MOOV_USERNAME=
MOOV_PASSWORD=

# ── Email transactionnel ─────────────────────────────────────────
# Providers : log (preprod sans envoi), smtp, brevo, resend
MAIL_PROVIDER=log
MAIL_FROM_EMAIL=no_reply@myna-etoile.com
MAIL_FROM_NAME=MynaPay
MAIL_API_URL=
MAIL_API_KEY=
MAIL_TIMEOUT_SECONDS=10
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=no_reply@myna-etoile.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993

# ── Worker ─────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
MAX_RETRIES=3
RETRY_DELAY_SECONDS=30

# ── Platform ───────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=0.015
VALIDATION_THRESHOLD=500000
