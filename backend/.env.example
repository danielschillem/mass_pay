# ── Server ─────────────────────────────────────────────────────
PORT=8080
GIN_MODE=debug   # release en prod

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgres://masspay:secret@localhost:5432/masspay_bf?sslmode=disable

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=changeme_min_32_chars_in_production
JWT_EXPIRY_HOURS=24
REFRESH_EXPIRY_DAYS=30

# ── Orange Money BF ────────────────────────────────────────────
ORANGE_BASE_URL=https://api.orange.com/orange-money-webpay/bf/v1
ORANGE_API_KEY=
ORANGE_ACCOUNT_ID=
ORANGE_PIN=

# ── Moov Money BF ──────────────────────────────────────────────
MOOV_BASE_URL=https://openapi.moov.africa/bf/v1
MOOV_API_KEY=
MOOV_ACCOUNT_ID=

# ── Worker ─────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
MAX_RETRIES=3
RETRY_DELAY_SECONDS=30

# ── Platform ───────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=0.015
VALIDATION_THRESHOLD=500000   # FCFA — double approbation au-dessus
