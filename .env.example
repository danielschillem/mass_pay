# ── Environnement ──────────────────────────────────────────────
ENV=dev
PORT=8080
GIN_MODE=debug
LOG_LEVEL=debug

# ── Obligatoire ────────────────────────────────────────────────
JWT_SECRET=changeme_minimum_32_caracteres_en_production

# ── Base de données ────────────────────────────────────────────
DB_PASSWORD=masspay_secret
DATABASE_URL=postgres://masspay:masspay_secret@localhost:5432/masspay_bf?sslmode=disable
REDIS_URL=redis://localhost:6379

# ── JWT (rotation) ─────────────────────────────────────────────
JWT_SECRET_PREVIOUS=   # Ancien secret pour valider les tokens signés avant rotation
JWT_EXPIRY_HOURS=24
REFRESH_EXPIRY_DAYS=30

# ── Seed super admin (dev) ─────────────────────────────────────
SEED_SUPER_ADMIN=true
SUPER_ADMIN_EMAIL=admin@mynapay.bf
SUPER_ADMIN_PASSWORD=MynaPay@2026!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=60

# ── Orange Money BF — Online Payment API (XML-RPC) ─────────────
# Environnement actif : "test" ou "production"
ORANGE_MONEY_ENV=test
ORANGE_MONEY_TEST_URL=https://testom.orange.bf/
ORANGE_MONEY_PROD_URL=https://apiom.orange.bf/
# MSISDN marchand MynaPay enregistré chez Orange BF
ORANGE_MONEY_MERCHANT_MSISDN=
# Identifiants API fournis par Orange BF
ORANGE_MONEY_API_USERNAME=
ORANGE_MONEY_API_PASSWORD=
# Valeurs fixes imposées par la spec Orange BF
ORANGE_MONEY_PROVIDER=101
ORANGE_MONEY_PAYID=12
# Certificats mTLS Orange BF (obligatoires en production)
# Chemins lus par le backend dans Docker. Les fichiers sont montés depuis
# ORANGE_MONEY_CERTS_DIR, qui doit rester hors Git.
ORANGE_MONEY_CERTS_DIR=./certs/orange
ORANGE_MONEY_CERT_PUBLIC_CONTAINER=/run/secrets/orange/star_orange_bf.pem
ORANGE_MONEY_CERT_PRIVATE_CONTAINER=/run/secrets/orange/OrangeBFV22026.key

# ── Moov Money BF — Online Merchant USSD Push (Huawei) ─────────
# Environnement actif : "test" ou "production"
MOOV_ENV=test
# UAT  (test)       : https://uat.moov-money.bf:38443
MOOV_TEST_URL=https://uat.moov-money.bf:38443
# Production        : URL fournie par Moov Money à la mise en prod
MOOV_PROD_URL=
# Identifiants Basic Auth fournis par Moov Money Team
MOOV_USERNAME=
MOOV_PASSWORD=

# ── Email transactionnel — Hostinger ─────────────────────────────
MAIL_FROM_EMAIL=no_reply@myna-etoile.com
MAIL_FROM_NAME=MynaPay
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=no_reply@myna-etoile.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993

# ── Workers ────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
MAX_RETRIES=3
RETRY_DELAY_SECONDS=30

# ── Commission & Seuils ───────────────────────────────────────
DEFAULT_COMMISSION_RATE=0.015
VALIDATION_THRESHOLD=500000

# ── Backup PostgreSQL ─────────────────────────────────────────
BACKUP_PG_DATABASE=masspay_bf
BACKUP_PG_USER=masspay
BACKUP_PG_PASSWORD=${DB_PASSWORD}
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-west-3
